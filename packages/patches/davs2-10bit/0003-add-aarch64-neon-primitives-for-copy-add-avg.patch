+{\
+    int y;\
+    for (y = 0; y < h; y++) {\
+        davs2_blockcopy_pp_neon_row(a, b, w);\
+        a += stridea;\
+        b += strideb;\
+    }\
+}
+
+#define BLOCKCOPY_SS_NEON(w, h) \
