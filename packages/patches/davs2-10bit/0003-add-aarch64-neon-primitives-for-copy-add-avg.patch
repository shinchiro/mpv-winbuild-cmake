+static inline void davs2_blockcopy_pp_neon_row(pel_t *dst, const pel_t *src, int width)
+{
+    int x = 0;
+    for (; x <= width - 16; x += 16) {
+        vst1q_u16(dst + x, vld1q_u16(src + x));
+        vst1q_u16(dst + x + 8, vld1q_u16(src + x + 8));
+    }
+    for (; x <= width - 8; x += 8) {
+        vst1q_u16(dst + x, vld1q_u16(src + x));
+    }
+    for (; x < width; x++) {
+        dst[x] = src[x];
+    }
+}
+
+static inline void davs2_blockcopy_ss_neon_row(coeff_t *dst, const coeff_t *src, int width)
+{
+    int x = 0;
+    for (; x <= width - 16; x += 16) {
+        vst1q_s16(dst + x, vld1q_s16(src + x));
+        vst1q_s16(dst + x + 8, vld1q_s16(src + x + 8));
+    }
+    for (; x <= width - 8; x += 8) {
+        vst1q_s16(dst + x, vld1q_s16(src + x));
+    }
+    for (; x < width; x++) {
+        dst[x] = src[x];
+    }
+}
+
+static inline void davs2_pixel_add_ps_neon_row(pel_t *dst, const pel_t *b0, const coeff_t *b1, int width)
+{
+    int x = 0;
+    const int16x8_t zero = vdupq_n_s16(0);
+    const int16x8_t maxv = vdupq_n_s16((int16_t)max_pel_value);
+    for (; x <= width - 8; x += 8) {
+        int16x8_t src0 = vreinterpretq_s16_u16(vld1q_u16(b0 + x));
+        int16x8_t delta = vld1q_s16(b1 + x);
+        int16x8_t sum = vaddq_s16(src0, delta);
+        sum = vmaxq_s16(sum, zero);
+        sum = vminq_s16(sum, maxv);
+        vst1q_u16(dst + x, vreinterpretq_u16_s16(sum));
+    }
+    for (; x < width; x++) {
+        dst[x] = (pel_t)DAVS2_CLIP1(b0[x] + b1[x]);
+    }
+}
+
+#define PIXEL_ADD_PS_NEON(w, h) \
+static void davs2_pixel_add_ps_##w##x##h##_neon(pel_t *a, intptr_t dstride, const pel_t *b0, const coeff_t* b1, intptr_t sstride0, intptr_t sstride1)\
+{\
+    int y;\
+    for (y = 0; y < h; y++) {\
+        davs2_pixel_add_ps_neon_row(a, b0, b1, w);\
+        b0 += sstride0;\
+        b1 += sstride1;\
+        a  += dstride;\
+    }\
+}
+
+#define BLOCKCOPY_PP_NEON(w, h) \
