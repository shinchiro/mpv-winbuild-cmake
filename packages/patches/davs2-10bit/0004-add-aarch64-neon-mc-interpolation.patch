+#if ARCH_AARCH64 && HIGH_BIT_DEPTH
+static inline uint16x8_t davs2_clip_int32x4x2_to_u16_neon(int32x4_t lo, int32x4_t hi)
+{
+    const int32x4_t zero = vdupq_n_s32(0);
+    const int32x4_t maxv = vdupq_n_s32(max_pel_value);
+    lo = vmaxq_s32(lo, zero);
+    hi = vmaxq_s32(hi, zero);
+    lo = vminq_s32(lo, maxv);
+    hi = vminq_s32(hi, maxv);
+    return vcombine_u16(vqmovun_s32(lo), vqmovun_s32(hi));
+}
+
+static void intpl_chroma_block_hor_neon(pel_t *dst, int i_dst, pel_t *src, int i_src, int width, int height, int8_t const *coeff)
+{
+    const int16_t c0 = coeff[0], c1 = coeff[1], c2 = coeff[2], c3 = coeff[3];
+    pel_t *src_base = src;
+    int x, y, v;
+    src -= 1;
+    for (y = 0; y < height; y++) {
+        for (x = 0; x <= width - 8; x += 8) {
+            int16x8_t s0 = vreinterpretq_s16_u16(vld1q_u16(src + x + 0));
+            int16x8_t s1 = vreinterpretq_s16_u16(vld1q_u16(src + x + 1));
+            int16x8_t s2 = vreinterpretq_s16_u16(vld1q_u16(src + x + 2));
+            int16x8_t s3 = vreinterpretq_s16_u16(vld1q_u16(src + x + 3));
+            int32x4_t lo = vmull_n_s16(vget_low_s16(s0), c0);
+            int32x4_t hi = vmull_n_s16(vget_high_s16(s0), c0);
+            lo = vmlal_n_s16(lo, vget_low_s16(s1), c1);
+            hi = vmlal_n_s16(hi, vget_high_s16(s1), c1);
+            lo = vmlal_n_s16(lo, vget_low_s16(s2), c2);
+            hi = vmlal_n_s16(hi, vget_high_s16(s2), c2);
+            lo = vmlal_n_s16(lo, vget_low_s16(s3), c3);
+            hi = vmlal_n_s16(hi, vget_high_s16(s3), c3);
+            lo = vshrq_n_s32(vaddq_s32(lo, vdupq_n_s32(32)), 6);
+            hi = vshrq_n_s32(vaddq_s32(hi, vdupq_n_s32(32)), 6);
+            vst1q_u16(dst + x, davs2_clip_int32x4x2_to_u16_neon(lo, hi));
+        }
+        for (; x < width; x++) {
+            v = (FLT_4TAP_HOR(src_base, x, coeff) + 32) >> 6;
+            dst[x] = (pel_t)DAVS2_CLIP1(v);
+        }
+        src += i_src;
+        src_base += i_src;
+        dst += i_dst;
+    }
+}
