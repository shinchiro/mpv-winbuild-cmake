+static void intpl_chroma_block_ext_neon(pel_t *dst, int i_dst, pel_t *src, int i_src, int width, int height, const int8_t *coeff_h, const int8_t *coeff_v)
+{
+    ALIGN16(mct_t tmp_res[(32 + 3) * 32]);
+    mct_t *tmp = tmp_res;
+    const int shift2 = 20 - g_bit_depth;
+    const int add2   = 1 << (shift2 - 1);
+    const int16_t h0 = coeff_h[0], h1 = coeff_h[1], h2 = coeff_h[2], h3 = coeff_h[3];
+    const int16_t v0 = coeff_v[0], v1 = coeff_v[1], v2 = coeff_v[2], v3 = coeff_v[3];
+    int x, y, v;
+
+    src -= i_src;
+    for (y = -1; y < height + 2; y++) {
+        for (x = 0; x <= width - 8; x += 8) {
+            int16x8_t s0 = vreinterpretq_s16_u16(vld1q_u16(src + x - 1));
+            int16x8_t s1 = vreinterpretq_s16_u16(vld1q_u16(src + x + 0));
+            int16x8_t s2 = vreinterpretq_s16_u16(vld1q_u16(src + x + 1));
+            int16x8_t s3 = vreinterpretq_s16_u16(vld1q_u16(src + x + 2));
+            int32x4_t lo = vmull_n_s16(vget_low_s16(s0), h0);
+            int32x4_t hi = vmull_n_s16(vget_high_s16(s0), h0);
+            lo = vmlal_n_s16(lo, vget_low_s16(s1), h1);
+            hi = vmlal_n_s16(hi, vget_high_s16(s1), h1);
+            lo = vmlal_n_s16(lo, vget_low_s16(s2), h2);
+            hi = vmlal_n_s16(hi, vget_high_s16(s2), h2);
+            lo = vmlal_n_s16(lo, vget_low_s16(s3), h3);
+            hi = vmlal_n_s16(hi, vget_high_s16(s3), h3);
+            vst1q_s16(tmp + x, vcombine_s16(vqmovn_s32(vshrq_n_s32(vaddq_s32(lo, vdupq_n_s32(2)), 2)), vqmovn_s32(vshrq_n_s32(vaddq_s32(hi, vdupq_n_s32(2)), 2))));
+        }
+        for (; x < width; x++) {
+            v = FLT_4TAP_HOR(src, x, coeff_h);
+            tmp[x] = (mct_t)((v + 2) >> 2);
+        }
+        src += i_src;
+        tmp += 32;
+    }
+
+    tmp = tmp_res + 32;
+    for (y = 0; y < height; y++) {
+        for (x = 0; x <= width - 8; x += 8) {
+            int16x8_t s0 = vld1q_s16(tmp + x - 32);
+            int16x8_t s1 = vld1q_s16(tmp + x + 0);
+            int16x8_t s2 = vld1q_s16(tmp + x + 32);
+            int16x8_t s3 = vld1q_s16(tmp + x + 64);
+            int32x4_t lo = vmull_n_s16(vget_low_s16(s0), v0);
+            int32x4_t hi = vmull_n_s16(vget_high_s16(s0), v0);
+            lo = vmlal_n_s16(lo, vget_low_s16(s1), v1);
+            hi = vmlal_n_s16(hi, vget_high_s16(s1), v1);
+            lo = vmlal_n_s16(lo, vget_low_s16(s2), v2);
+            hi = vmlal_n_s16(hi, vget_high_s16(s2), v2);
+            lo = vmlal_n_s16(lo, vget_low_s16(s3), v3);
+            hi = vmlal_n_s16(hi, vget_high_s16(s3), v3);
+            lo = vshrq_n_s32(vaddq_s32(lo, vdupq_n_s32(add2)), 10);
+            hi = vshrq_n_s32(vaddq_s32(hi, vdupq_n_s32(add2)), 10);
+            vst1q_u16(dst + x, davs2_clip_int32x4x2_to_u16_neon(lo, hi));
+        }
+        for (; x < width; x++) {
+            v = (FLT_4TAP_VER(tmp, x, 32, coeff_v) + add2) >> shift2;
+            dst[x] = (pel_t)DAVS2_CLIP1(v);
+        }
+        dst += i_dst;
+        tmp += 32;
+    }
+}
